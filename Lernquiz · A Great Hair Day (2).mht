<!DOCTYPE html><html lang="de"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8"><link rel="stylesheet" type="text/css" href="cid:css-e0f7bc59-9b84-434c-b27a-7ae1ccce1c0e@mhtml.blink" />

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lernquiz · A Great Hair Day</title>


</head>
<body>

<div class="kopf">
  <div class="kopf-klein">A Great Hair Day · Lehrlingsbegleitung</div>
  <h1>Lernquiz ✂</h1>
  <p>Österreichisches Berufsbild Friseur/in</p>
</div>

<div id="s-login" class="seite aktiv">
  <div style="padding-top:32px">
    <div class="lab" style="margin-bottom:16px;font-size:13px;color:#2C2C2C;text-transform:none;letter-spacing:0">Bitte einloggen</div>
    <div id="login-fehler" class="fehler-box" style="display:none"></div>
    <div class="lab">Name</div>
    <input type="text" id="login-name" placeholder="Dein Name (z.B. Ronya)" autocomplete="off">
    <div class="lab">PIN</div>
    <input type="password" id="login-pin" placeholder="6-stellige PIN" maxlength="6" inputmode="numeric" style="margin-bottom:16px">
    <button class="btn btn-d" id="btn-login">Einloggen →</button>
    <button class="link-k" id="btn-zu-meisterin">Meisterinnen-Login</button>
  </div>
</div>

<div id="s-mlogin" class="seite">
  <div style="padding-top:32px">
    <h2 style="font-family:Georgia,serif;font-weight:normal;font-size:20px;margin-bottom:20px">Meisterinnen-Login</h2>
    <div id="mlogin-fehler" class="fehler-box" style="display:none"></div>
    <div class="lab">E-Mail</div>
    <input type="email" id="mlogin-email" value="mirjam.walenta@gmail.com">
    <div class="lab">Passwort</div>
    <input type="password" id="mlogin-pw" placeholder="Passwort" style="margin-bottom:16px">
    <button class="btn btn-d" id="btn-mlogin">Einloggen →</button>
    <button class="btn btn-h" id="btn-mlogin-back">← Zurück</button>
  </div>
</div>

<div id="s-start" class="seite">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-top:20px;margin-bottom:20px">
    <div>
      <div class="lab">Lehrling</div>
      <div id="start-name" style="font-family:Georgia,serif;font-size:20px;color:#2C2C2C"></div>
    </div>
    <button id="btn-logout" style="background:none;border:1.5px solid #DDD8D0;border-radius:8px;padding:7px 12px;font-size:12px;color:#9A9188;cursor:pointer;font-family:system-ui">Abmelden</button>
  </div>
  <div id="start-letztes"></div>
  <div style="margin-bottom:18px">
    <div class="lab">Lehrjahr</div>
    <div class="lj-r">
      <button class="lj-b" id="lj1">1. Lehrjahr</button>
      <button class="lj-b" id="lj2">2. Lehrjahr</button>
      <button class="lj-b" id="lj3">3. Lehrjahr</button>
    </div>
  </div>
  <div style="margin-bottom:24px">
    <div class="lab">Modus</div>
    <button class="mod-b" id="mod-schnell"><div class="mod-t">Schnell-Check</div><div class="mod-i">10 Fragen · 10 Min</div></button>
    <button class="mod-b" id="mod-tief"><div class="mod-t">Lerneinheit</div><div class="mod-i">15 Fragen · 20 Min</div></button>
    <button class="mod-b" id="mod-lap"><div class="mod-t">LAP-Vorbereitung</div><div class="mod-i">Alle Fragen</div></button>
  </div>
  <button class="btn btn-d" id="btn-quiz-los">Quiz starten →</button>
  <button class="link-k" id="btn-verlauf-zeigen">Verlauf ansehen</button>
</div>

<div id="s-quiz" class="seite">
  <div class="prog"><div class="prog-f" id="prog" style="width:0%"></div></div>
  <div style="padding:16px 0 0">
    <div class="meta"><span id="q-nr"></span><span id="q-badge"></span></div>
    <div style="font-size:10px;color:#9A9188;margin-bottom:10px" id="q-thema"></div>
    <div class="frage-box"><div class="frage-txt" id="q-txt"></div></div>
    <div id="q-antwort"></div>
    <div id="q-feedback" style="display:none"></div>
    <div id="q-btns"></div>
  </div>
</div>

<div id="s-ergebnis" class="seite">
  <div style="padding-top:20px">
    <div class="score-box" id="score-box"></div>
    <div id="erg-details"></div>
    <button class="btn btn-d" id="btn-neu-quiz">Neues Quiz starten</button>
  </div>
</div>

<div id="s-verlauf" class="seite">
  <div style="padding-top:20px">
    <h2 style="font-family:Georgia,serif;font-weight:normal;font-size:20px;margin-bottom:16px">Verlauf</h2>
    <div id="v-liste"><div class="laden">Wird geladen…</div></div>
    <button class="btn btn-h" id="btn-v-zurueck">← Zurück</button>
  </div>
</div>

<div id="s-dashboard" class="seite">
  <div style="padding-top:20px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
      <h2 style="font-family:Georgia,serif;font-weight:normal;font-size:20px">Übersicht</h2>
      <button id="btn-m-logout" style="background:none;border:1.5px solid #DDD8D0;border-radius:8px;padding:7px 12px;font-size:12px;color:#9A9188;cursor:pointer;font-family:system-ui">Abmelden</button>
    </div>
    <div style="display:flex;gap:8px;margin-bottom:20px">
      <button class="btn btn-h" id="btn-lehrling-neu" style="margin:0">+ Lehrling anlegen</button>
      <button class="btn btn-h" id="btn-fragen-verw" style="margin:0">✎ Fragen</button>
    </div>
    <div id="dashboard-liste"><div class="laden">Wird geladen…</div></div>
  </div>
</div>

<div id="s-neu-lehrling" class="seite">
  <div style="padding-top:20px">
    <h2 style="font-family:Georgia,serif;font-weight:normal;font-size:20px;margin-bottom:20px">Neuen Lehrling anlegen</h2>
    <div id="neu-fehler" class="fehler-box" style="display:none"></div>
    <div class="lab">Name</div>
    <input type="text" id="neu-name" placeholder="z.B. Ronya">
    <div class="lab">Lehrjahr</div>
    <select id="neu-lj" style="margin-bottom:10px">
      <option value="1">1. Lehrjahr</option>
      <option value="2">2. Lehrjahr</option>
      <option value="3">3. Lehrjahr</option>
    </select>
    <div class="lab">PIN (6 Stellen)</div>
    <input type="text" id="neu-pin" placeholder="z.B. 123456" maxlength="6" inputmode="numeric" style="margin-bottom:16px">
    <button class="btn btn-g" id="btn-neu-speichern">Lehrling anlegen</button>
    <button class="btn btn-h" id="btn-neu-back">← Zurück</button>
  </div>
</div>

<div id="s-lehrling-detail" class="seite">
  <div style="padding-top:20px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
      <h2 style="font-family:Georgia,serif;font-weight:normal;font-size:20px" id="detail-name"></h2>
      <button class="btn btn-h" id="btn-detail-back" style="width:auto;padding:8px 14px;margin:0;font-size:12px">← Zurück</button>
    </div>
    <div id="detail-inhalt"><div class="laden">Wird geladen…</div></div>
  </div>
</div>

<div id="s-verw" class="seite">
  <div style="padding-top:20px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <h2 style="font-family:Georgia,serif;font-weight:normal;font-size:20px">Fragen</h2>
      <button class="btn btn-h" id="btn-verw-back" style="width:auto;padding:8px 14px;margin:0;font-size:12px">← Zurück</button>
    </div>
    <div class="lj-r">
      <button class="lj-b" id="vlj1">1. LJ</button>
      <button class="lj-b" id="vlj2">2. LJ</button>
      <button class="lj-b" id="vlj3">3. LJ</button>
    </div>
    <div id="verw-liste"></div>
    <button class="btn btn-h" id="btn-verw-neu" style="border:2px dashed #DDD8D0;background:none;color:#9A9188">+ Neue Frage</button>
  </div>
</div>

<div id="s-editor" class="seite">
  <div style="padding-top:20px">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
      <h2 style="font-family:Georgia,serif;font-weight:normal;font-size:18px" id="ed-titel">Frage</h2>
      <button class="btn btn-h" id="btn-ed-back" style="width:auto;padding:8px 14px;margin:0;font-size:12px">← Zurück</button>
    </div>
    <div id="ed-inhalt"></div>
  </div>
</div>




</body></html>
