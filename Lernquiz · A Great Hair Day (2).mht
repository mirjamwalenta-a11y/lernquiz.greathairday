.ml-lab { font-size: 10px; color: rgb(107, 143, 113); font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 5px; }

.ml-txt { font-size: 13px; color: rgb(249, 247, 244); line-height: 1.55; }

.score-box { background: rgb(237, 232, 224); border-radius: 12px; padding: 14px 16px; margin-bottom: 16px; }

