.kopf h1 { font-family: Georgia, serif; font-size: 22px; color: rgb(249, 247, 244); font-weight: normal; }

.kopf p { font-size: 11px; color: rgb(90, 85, 80); margin-top: 3px; }

.btn { display: block; width: 100%; padding: 14px; border-width: medium; border-style: none; border-color: currentcolor; border-image: none; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; margin-bottom: 10px; font-family: system-ui; text-align: center; }

.btn-d { background: rgb(44, 44, 44); color: rgb(249, 247, 244); }

.btn-g { background: rgb(107, 143, 113); color: rgb(249, 247, 244); }

.btn-h { background: rgb(237, 232, 224); color: rgb(44, 44, 44); }

.btn-r { background: rgb(237, 232, 224); color: rgb(196, 64, 48); }

.btn-grau { background: rgb(221, 216, 208); color: rgb(154, 145, 136); }

input, select, textarea { width: 100%; border: 1.5px solid rgb(221, 216, 208); border-radius: 8px; padding: 10px 12px; font-size: 14px; font-family: system-ui; background: rgb(255, 255, 255); outline: none; margin-bottom: 10px; }

textarea { resize: vertical; margin-bottom: 0px; }

.lj-r { display: flex; gap: 8px; margin-bottom: 16px; }

.lj-b { flex: 1 1 0%; padding: 11px 4px; border-radius: 10px; border: 2px solid rgb(221, 216, 208); background: rgb(255, 255, 255); font-size: 12px; cursor: pointer; font-family: system-ui; text-align: center; }

.lj-b.a1 { border-color: rgb(143, 175, 122); background: rgba(143, 175, 122, 0.133); color: rgb(90, 138, 90); font-weight: 700; }

.lj-b.a2 { border-color: rgb(196, 184, 106); background: rgba(196, 184, 106, 0.133); color: rgb(138, 122, 48); font-weight: 700; }

.lj-b.a3 { border-color: rgb(212, 169, 122); background: rgba(212, 169, 122, 0.133); color: rgb(138, 96, 48); font-weight: 700; }

.mod-b { width: 100%; padding: 13px 14px; border-radius: 10px; border: 2px solid rgb(221, 216, 208); background: rgb(255, 255, 255); margin-bottom: 8px; text-align: left; cursor: pointer; font-family: system-ui; }

.mod-b.ak { border-color: rgb(107, 143, 113); background: rgba(107, 143, 113, 0.082); }

.mod-t { font-size: 14px; font-weight: 600; color: rgb(44, 44, 44); }

.mod-i { font-size: 11px; color: rgb(154, 145, 136); margin-top: 2px; }

.prog { height: 4px; background: rgb(237, 232, 224); }

.prog-f { height: 4px; background: rgb(107, 143, 113); transition: width 0.3s; }

.frage-box { background: rgb(44, 44, 44); border-radius: 12px; padding: 20px; margin-bottom: 14px; }

.frage-txt { font-family: Georgia, serif; font-size: 16px; color: rgb(249, 247, 244); line-height: 1.55; }

.meta { font-size: 11px; color: rgb(154, 145, 136); margin-bottom: 8px; display: flex; justify-content: space-between; }

.badge { display: inline-block; border-radius: 20px; padding: 2px 9px; font-size: 10px; font-weight: 700; }

.bmc { background: rgba(143, 175, 122, 0.133); color: rgb(90, 138, 90); border: 1px solid rgb(143, 175, 122); }

.bof { background: rgba(196, 184, 106, 0.133); color: rgb(138, 122, 48); border: 1px solid rgb(196, 184, 106); }

.opt { width: 100%; padding: 12px 14px; border-radius: 10px; border: 2px solid rgb(221, 216, 208); background: rgb(255, 255, 255); text-align: left; font-size: 13px; cursor: pointer; margin-bottom: 8px; font-family: system-ui; line-height: 1.4; display: block; }

.opt.gew { border-color: rgb(44, 44, 44); background: rgba(44, 44, 44, 0.05); }

.opt.ric { border-color: rgb(107, 143, 113); background: rgba(143, 175, 122, 0.133); color: rgb(61, 107, 80); }

.opt.fal { border-color: rgb(196, 64, 48); background: rgba(212, 88, 72, 0.125); color: rgb(196, 64, 48); }

.fb { border-radius: 12px; padding: 16px; margin-bottom: 12px; }

.fb-g { background: rgba(143, 175, 122, 0.133); border: 1.5px solid rgb(107, 143, 113); }

.fb-o { background: rgba(196, 184, 106, 0.133); border: 1.5px solid rgb(196, 184, 106); }

.fb-r { background: rgba(212, 88, 72, 0.125); border: 1.5px solid rgb(196, 64, 48); }

