.lab { display: block; font-size: 10px; font-weight: 700; letter-spacing: 1px; color: rgb(154, 145, 136); text-transform: uppercase; margin-bottom: 6px; }

.link-k { background: none; border-width: medium; border-style: none; border-color: currentcolor; border-image: none; color: rgb(200, 192, 184); font-size: 11px; cursor: pointer; font-family: system-ui; text-decoration: underline; display: block; text-align: center; margin-top: 12px; padding: 6px; width: 100%; }

.laden { text-align: center; padding: 40px 20px; color: rgb(154, 145, 136); font-size: 13px; }

.fehler-box { background: rgba(212, 88, 72, 0.125); border: 1.5px solid rgb(196, 64, 48); border-radius: 10px; padding: 12px 14px; color: rgb(196, 64, 48); font-size: 13px; margin-bottom: 12px; }
