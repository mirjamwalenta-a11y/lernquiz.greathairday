@charset "utf-8";

* { box-sizing: border-box; margin: 0px; padding: 0px; }

body { font-family: system-ui, sans-serif; background: rgb(249, 247, 244); min-height: 100vh; }

.seite { display: none; max-width: 640px; margin: 0px auto; padding: 20px; }

.seite.aktiv { display: block; }

.kopf { background: rgb(44, 44, 44); padding: 18px 20px; }

